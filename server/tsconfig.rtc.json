{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": [
    "src/rtcServer.ts",
    "src/config/**/*.ts",
    "src/constants/**/*.ts",
    "src/controllers/**/*.ts",
    "src/middleware/**/*.ts",
    "src/models/**/*.ts",
    "src/routes/**/*.ts",
    "src/services/rtcService.ts",
    "src/sockets/**/*.ts",
    "src/types/**/*.ts",
    "src/utils/**/*.ts"
  ]
}
